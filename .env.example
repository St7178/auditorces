# OpenAI API key used by CES Guardian (chat + embeddings para la base de conocimiento).
# Se lee en tiempo de ejecución (src/routes/api/chat.ts) y en el script de ingesta (scripts/ingest-knowledge.mjs).
OPENAI_API_KEY=

# Autenticación con Microsoft Entra ID (Azure AD). Ver App Registration en portal.azure.com.
# Client ID / Tenant ID no son secretos; el Client Secret SÍ lo es — nunca lo commitees ni lo compartas.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
# Debe coincidir EXACTO con un Redirect URI configurado en Azure (plataforma "Web").
ENTRA_REDIRECT_URI=http://localhost:3000/api/auth/callback
# Origen público de la app (sin slash final) — usado para el logout y validar el callback.
APP_ORIGIN=http://localhost:3000

# Secreto usado para cifrar/firmar las cookies de sesión (login y estado OAuth). Genera uno con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
